// Prisma schema for the quiz app.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Pooled connection (Supabase: port 6543, ?pgbouncer=true). Used by the app at runtime.
  url = env("DATABASE_URL")
  // Direct connection (Supabase: port 5432). Used by `prisma migrate` / `prisma db push`.
  directUrl = env("DIRECT_URL")
}

model Question {
  id        String   @id @default(cuid())
  text      String
  options   Option[]
  createdAt DateTime @default(now())
}

model Option {
  id         String   @id @default(cuid())
  text       String
  isCorrect  Boolean  @default(false)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

// One row per completed quiz attempt, used for admin engagement stats and
// for letting a user re-open their result later via a short code.
model Submission {
  id        String   @id @default(cuid())
  code      String   @unique // 6-digit code the user enters to re-view this result
  score     Int // marks the user got
  total     Int // total marks available at the time
  name      String? // optional name the user entered, shown on the result card
  category  String? // UR | OBC | SC | ST — drives the selection cutoff shown
  avatar    String? // id of the chosen avatar, shown on the result card
  answers   Json // { [questionId]: optionId } — used to rebuild the review screen
  order     Json // string[] of question ids in the order shown — to rebuild the review
  createdAt DateTime @default(now())

  @@index([createdAt])
}
